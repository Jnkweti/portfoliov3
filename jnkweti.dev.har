          "content": {
            "size": 7177,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html><html lang=\"en\"> <head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width\"><link rel=\"icon\" type=\"image/svg+xml\" href=\"/portfoliov3/favicon.svg\"><link rel=\"icon\" href=\"/portfoliov3/favicon.ico\"><meta name=\"generator\" content=\"Astro v5.17.3\"><meta name=\"description\" content=\"The requested page could not be found\"><script>\n\t\t\tdocument.documentElement.classList.add('js');\n\t\t</script><title>404 | Page Not Found</title><link rel=\"stylesheet\" href=\"/portfoliov3/_astro/about.Cfe3i2YQ.css\"></head> <body class=\"min-h-screen text-slate-100 antialiased selection:bg-sky-500/30\"> <div class=\"relative min-h-screen overflow-x-hidden\"> <div class=\"pointer-events-none absolute inset-0 -z-10 overflow-hidden\"> <div class=\"floating-orb floating-orb--one\"></div> <div class=\"floating-orb floating-orb--two\"></div> <div class=\"floating-orb floating-orb--three\"></div> </div> <header class=\"sticky top-0 z-50 border-b border-white/10 bg-slate-950/80 backdrop-blur\"> <div class=\"mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8\"> <a href=\"/portfoliov3/\" class=\"text-lg font-bold tracking-tight text-white\">\nJoshua<span class=\"text-sky-400\">.</span> </a> <button id=\"mobile-nav-toggle\" type=\"button\" class=\"inline-flex items-center rounded-md border border-white/15 px-3 py-1.5 text-sm text-slate-200 md:hidden\" aria-controls=\"site-nav\" aria-expanded=\"false\">\nMenu\n</button> <nav id=\"site-nav\" class=\"hidden w-full flex-col gap-2 border-t border-white/10 pt-4 md:flex md:w-auto md:flex-row md:items-center md:gap-6 md:border-0 md:pt-0\"> <a href=\"/portfoliov3/about/\" class=\"nav-link text-sm \"> About </a><a href=\"/portfoliov3/skills/\" class=\"nav-link text-sm \"> Skills </a><a href=\"/portfoliov3/projects/\" class=\"nav-link text-sm \"> Projects </a><a href=\"/portfoliov3/experience/\" class=\"nav-link text-sm \"> Experience </a><a href