---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Projects | Joshua Nkweti-Nyong" description="Selected engineering and DevSecOps projects">
	<section class="page-shell">
		<header class="page-header" data-reveal>
			<h1 class="section-title gradient-heading">Projects & Work</h1>
			<p class="subtle-text max-w-2xl">
				This section is still being built out. In the meantime, you can browse my repositories on GitHub.
			</p>
		</header>

		<article class="glass-card project-card max-w-3xl p-7 md:p-8" data-reveal data-tilt>
			<span class="role-badge">Work In Progress</span>
			<h2 class="mt-4 text-2xl font-semibold text-white">Project showcase coming soon</h2>
			<p class="subtle-text mt-3">
				I'm currently refining this section with deeper project write-ups, architecture notes, and demo links.
				You can still see my current code and experiments in my public repositories.
			</p>
			<div class="mt-6">
				<a
					class="glow-btn"
					href="https://github.com/Jnkweti"
					target="_blank"
					rel="noopener noreferrer"
				>
					View GitHub Repositories
				</a>
			</div>
		</article>
	</section>
</Layout>
