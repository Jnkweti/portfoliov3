---
import { projects } from '../../data/portfolio';
import Layout from '../../layouts/Layout.astro';
import { withBase } from '../../lib/site';

const sortedProjects = [...projects].sort((a, b) => a.sortOrder - b.sortOrder);
---

<Layout title="Projects | Joshua Nkweti-Nyong" description="Selected engineering and DevSecOps projects">
	<section class="page-shell">
		<header class="page-header" data-reveal>
			<h1 class="section-title gradient-heading">Projects & Work</h1>
			<p class="subtle-text max-w-2xl">A selection of systems I've built, secured, and shipped.</p>
		</header>

		<div class="grid gap-5 sm:grid-cols-2">
			{
				sortedProjects.map((project) => (
					<article class="glass-card project-card flex h-full flex-col p-6" data-reveal data-tilt>
						<div class="mb-3 flex flex-wrap gap-2">
							{project.isFeatured && (
								<span class="rounded-full border border-sky-300/40 bg-sky-500/15 px-2.5 py-1 text-xs font-semibold text-sky-200">
									Featured
								</span>
							)}
							{
								project.tags.map((tag) => (
									<span class="rounded-full border border-white/15 bg-slate-900/80 px-2.5 py-1 text-xs text-slate-300">
										{tag}
									</span>
								))
							}
						</div>

						<h2 class="text-xl font-semibold text-white">{project.title}</h2>
						<p class="mt-3 flex-1 text-sm leading-relaxed text-slate-300">{project.summary}</p>

						<div class="mt-5 flex flex-wrap gap-2">
							<a class="glow-btn" href={withBase(`projects/${project.id}/`)}>
								View Details
							</a>
							{
								project.repoUrl && (
									<a
										class="outline-btn"
										href={project.repoUrl}
										target="_blank"
										rel="noopener noreferrer"
									>
										Repository
									</a>
								)
							}
						</div>
					</article>
				))
			}
		</div>
	</section>
</Layout>
