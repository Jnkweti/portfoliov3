import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio V3">
	<main class="mx-auto flex min-h-screen w-full max-w-5xl items-center px-6 py-20">
		<section class="w-full rounded-2xl border border-white/10 bg-white/5 p-8 shadow-2xl shadow-black/30 md:p-12">
			<p class="text-sm uppercase tracking-[0.22em] text-sky-300">Stack Ready</p>
			<h1 class="mt-3 text-4xl font-bold leading-tight md:text-5xl">
				Astro + TypeScript + Tailwind CSS
			</h1>
			<p class="mt-5 max-w-3xl text-base leading-relaxed text-slate-300">
				This repository has been reset and rebuilt with your requested stack. GitHub Actions
				is configured to deploy the Astro static build to GitHub Pages.
			</p>
		</section>
	</main>
</Layout>
