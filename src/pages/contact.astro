---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Joshua Nkweti-Nyong" description="Get in touch with Joshua Nkweti-Nyong">
	<section class="page-shell space-y-10">
		<header class="page-header" data-reveal>
			<h1 class="section-title gradient-heading">Contact</h1>
			<p class="subtle-text">Have a question or want to collaborate? Send me a message.</p>
		</header>

		<div class="grid items-start gap-6 md:grid-cols-[1fr_1.6fr]">
			<div class="space-y-4">
				<div class="glass-card p-5" data-reveal data-tilt>
					<p class="text-xs uppercase tracking-wider text-slate-500">Email</p>
					<p class="mt-2 text-sm text-slate-200">joshuanyong02@gmail.com</p>
				</div>
				<div class="glass-card p-5" data-reveal data-tilt>
					<p class="text-xs uppercase tracking-wider text-slate-500">Location</p>
					<p class="mt-2 text-sm text-slate-200">Alexandria, VA | Remote Ready</p>
				</div>
				<div class="glass-card p-5" data-reveal data-tilt>
					<p class="text-xs uppercase tracking-wider text-slate-500">Response Time</p>
					<p class="mt-2 text-sm text-slate-200">Typically within 24 hours</p>
				</div>
				<div class="glass-card p-5" data-reveal data-tilt>
					<p class="text-xs uppercase tracking-wider text-slate-500">Socials</p>
					<div class="mt-2 flex gap-4 text-sm">
						<a
							class="text-slate-300 transition-colors hover:text-sky-300"
							href="https://github.com/Jnkweti"
							target="_blank"
							rel="noopener noreferrer"
						>
							GitHub
						</a>
						<a
							class="text-slate-300 transition-colors hover:text-sky-300"
							href="https://www.linkedin.com/in/joshua-n-52064b212"
							target="_blank"
							rel="noopener noreferrer"
						>
							LinkedIn
						</a>
					</div>
				</div>
			</div>

			<div class="glass-card p-6 md:p-7" data-reveal data-tilt>
				<form id="contact-form" class="space-y-4">
					<div>
						<label for="name" class="mb-1 block text-sm text-slate-300">Name</label>
						<input
							id="name"
							name="name"
							type="text"
							required
							maxlength="80"
							class="w-full rounded-lg border border-white/15 bg-slate-950/70 px-3 py-2 text-sm text-white placeholder:text-slate-500 focus:border-sky-500 focus:outline-none"
							placeholder="Your name"
						/>
					</div>
					<div>
						<label for="email" class="mb-1 block text-sm text-slate-300">Email</label>
						<input
							id="email"
							name="email"
							type="email"
							required
							maxlength="120"
							class="w-full rounded-lg border border-white/15 bg-slate-950/70 px-3 py-2 text-sm text-white placeholder:text-slate-500 focus:border-sky-500 focus:outline-none"
							placeholder="you@example.com"
						/>
					</div>
					<div>
						<label for="subject" class="mb-1 block text-sm text-slate-300">Subject</label>
						<input
							id="subject"
							name="subject"
							type="text"
							required
							maxlength="120"
							class="w-full rounded-lg border border-white/15 bg-slate-950/70 px-3 py-2 text-sm text-white placeholder:text-slate-500 focus:border-sky-500 focus:outline-none"
							placeholder="What's this about?"
						/>
					</div>
					<div>
						<label for="phone" class="mb-1 block text-sm text-slate-300">Phone</label>
						<input
							id="phone"
							name="phone"
							type="tel"
							required
							maxlength="32"
							pattern="[0-9+().\-\s]{7,32}"
							class="w-full rounded-lg border border-white/15 bg-slate-950/70 px-3 py-2 text-sm text-white placeholder:text-slate-500 focus:border-sky-500 focus:outline-none"
							placeholder="+1 (555) 000-0000"
						/>
					</div>
					<div>
						<label for="message" class="mb-1 block text-sm text-slate-300">Message</label>
						<textarea
							id="message"
							name="message"
							required
							rows="5"
							maxlength="2000"
							class="w-full rounded-lg border border-white/15 bg-slate-950/70 px-3 py-2 text-sm text-white placeholder:text-slate-500 focus:border-sky-500 focus:outline-none"
							placeholder="Tell me what you're thinking..."
						></textarea>
					</div>
					<div class="hidden" aria-hidden="true">
						<label for="website">Website</label>
						<input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
					</div>
					<div class="flex flex-wrap items-center gap-3">
						<button type="submit" class="glow-btn">Send Message</button>
						<span id="contact-status" class="text-xs text-slate-400"></span>
					</div>
				</form>
			</div>
		</div>
	</section>

	<script is:inline>
		const form = document.getElementById('contact-form');
		const status = document.getElementById('contact-status');
		const cleanSingleLine = (value, maxLength) =>
			String(value)
				.replace(/[\r\n]+/g, ' ')
				.replace(/\s{2,}/g, ' ')
				.trim()
				.slice(0, maxLength);
		const cleanMultiLine = (value, maxLength) =>
			String(value)
				.replace(/\u0000/g, '')
				.trim()
				.slice(0, maxLength);

		if (form && status) {
			form.addEventListener('submit', (event) => {
				event.preventDefault();

				if (!form.checkValidity()) {
					form.reportValidity();
					status.textContent = 'Please fix validation errors before submitting.';
					status.className = 'text-xs text-red-300';
					return;
				}

				const websiteTrap = document.getElementById('website').value;
				if (websiteTrap) {
					status.textContent = 'Unable to process request.';
					status.className = 'text-xs text-red-300';
					return;
				}

				const name = cleanSingleLine(document.getElementById('name').value, 80);
				const email = cleanSingleLine(document.getElementById('email').value, 120);
				const subject = cleanSingleLine(document.getElementById('subject').value, 120);
				const phone = cleanSingleLine(document.getElementById('phone').value, 32);
				const message = cleanMultiLine(document.getElementById('message').value, 2000);

				const body = [
					`Name: ${name}`,
					`Email: ${email}`,
					`Phone: ${phone}`,
					'',
					message,
				].join('\n');

				const mailto = `mailto:joshuanyong02@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
				status.textContent = 'Opening your email client...';
				status.className = 'text-xs text-emerald-300';
				window.location.href = mailto;
			});
		}
	</script>
</Layout>
