---
import { hobbies, roleBadges, socialLinks } from '../data/portfolio';
import { withBase } from '../lib/site';
---

<section class="page-shell space-y-10">
	<div class="glass-card p-7 md:p-10" data-reveal data-tilt>
		<div class="grid items-start gap-8 md:grid-cols-[11rem_1fr]">
			<div class="mx-auto w-36 md:w-44">
				<div class="rounded-full bg-[conic-gradient(from_0deg,#3b82f6,#60a5fa,#1d4ed8,#3b82f6)] p-1">
					<img
						src={withBase('assets/profilepic.jpg')}
						alt="Joshua Nkweti-Nyong"
						class="h-full w-full rounded-full object-cover object-top"
					/>
				</div>
			</div>

			<div class="space-y-5 text-center md:text-left">
				<h1 class="section-title gradient-heading">Joshua Nkweti-Nyong</h1>
				<div class="flex flex-wrap justify-center gap-2 md:justify-start">
					{
						roleBadges.map((badge) => (
							<span class="role-badge">{badge}</span>
						))
					}
				</div>
				<div class="flex flex-wrap justify-center gap-5 text-sm text-slate-400 md:justify-start">
					{
						socialLinks.map((social) => (
							<a href={social.href} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-sky-300">
								{social.label}
							</a>
						))
					}
				</div>
				<div class="border-t border-white/10 pt-5 text-sm font-semibold text-sky-200">
					ACTIVE TS/SCI SECURITY CLEARANCE
				</div>
				<p class="subtle-text">
					Air Force veteran with 4+ years of experience securing, automating, and maintaining
					enterprise-scale infrastructure across cloud and on-prem environments. Proven ability to
					integrate security into CI/CD pipelines, automate vulnerability remediation, harden
					infrastructure, and support highly regulated environments (NIST, ISO 27000, DoD).
				</p>
			</div>
		</div>
	</div>

	<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
		<div class="stat-card" data-reveal data-tilt>
			<p class="text-3xl font-bold text-sky-300">4+</p>
			<p class="mt-2 text-xs uppercase tracking-widest text-slate-500">Years Experience</p>
		</div>
		<div class="stat-card" data-reveal data-tilt>
			<p class="text-3xl font-bold text-sky-300">8</p>
			<p class="mt-2 text-xs uppercase tracking-widest text-slate-500">Certifications</p>
		</div>
		<div class="stat-card" data-reveal data-tilt>
			<p class="text-3xl font-bold text-sky-300">5+</p>
			<p class="mt-2 text-xs uppercase tracking-widest text-slate-500">Years Coding</p>
		</div>
		<div class="stat-card" data-reveal data-tilt>
			<p class="text-2xl font-bold text-sky-300">USAF</p>
			<p class="mt-2 text-xs uppercase tracking-widest text-slate-500">Veteran</p>
		</div>
	</div>

	<div class="grid gap-6 md:grid-cols-2">
		<div class="space-y-4" data-reveal>
			<h2 class="text-2xl font-semibold gradient-heading">Education</h2>
			<div class="glass-card p-6" data-tilt>
				<p class="font-medium text-white">M.S. Computer Science</p>
				<p class="mt-1 text-xs font-medium uppercase tracking-wider text-sky-300">In Progress</p>
				<p class="mt-2 text-sm text-slate-400">Western Governors University</p>
			</div>
			<div class="glass-card p-6" data-tilt>
				<p class="font-medium text-white">B.S. Computer Science</p>
				<p class="mt-1 text-xs font-medium uppercase tracking-wider text-sky-300">2024 | 3.6 GPA</p>
				<p class="mt-2 text-sm text-slate-400">Western Governors University</p>
			</div>
		</div>

		<div class="space-y-4" data-reveal>
			<h2 class="text-2xl font-semibold gradient-heading">Hobbies & Interests</h2>
			<div class="flex flex-wrap gap-2">
				{
					hobbies.map((hobby) => (
						<span class="role-badge border-slate-500/30 bg-slate-800/70 text-slate-200">{hobby}</span>
					))
				}
			</div>
		</div>
	</div>
</section>
